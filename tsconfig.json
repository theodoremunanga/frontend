{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,

    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "module": "ESNext",
    "moduleResolution": "Node",

    "jsx": "react-jsx",

    "strict": false,

    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,
    "isolatedModules": true,

    "noEmit": true,

    "baseUrl": "./",

    "paths": {
      "@/*": ["src/*"]
    }
  },

  "include": ["src"]
}