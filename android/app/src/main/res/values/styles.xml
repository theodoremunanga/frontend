<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">

        <!-- Brand colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>

        <!-- Remove default action bar -->
        <item name="windowActionModeOverlay">true</item>

        <!-- Window -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/colorPrimaryDark</item>

        <!-- Smooth rendering -->
        <item name="android:windowNoTitle">true</item>

    </style>


    <!-- App without toolbar -->
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Transparent background for Capacitor -->
        <item name="android:background">@android:color/transparent</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/colorPrimaryDark</item>

    </style>


    <!-- Android Launch Splash Screen -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">

        <!-- Splash background -->
        <item name="android:windowSplashScreenBackground">
            @color/splash_background
        </item>

        <!-- Adaptive logo -->
        <item name="android:windowSplashScreenAnimatedIcon">
            @drawable/ic_launcher_foreground
        </item>

        <!-- Splash animation duration -->
        <item name="android:windowSplashScreenAnimationDuration">
            500
        </item>

        <!-- After splash -->
        <item name="postSplashScreenTheme">
            @style/AppTheme.NoActionBar
        </item>

    </style>


</resources>